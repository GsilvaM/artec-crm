# App
APP_ENV=development
APP_URL=http://localhost:3100
APP_TIMEZONE=America/Sao_Paulo

# Supabase publico do CRM
VITE_CRM_SUPABASE_URL=
VITE_CRM_SUPABASE_ANON_KEY=

# Backend do CRM
VITE_CRM_API_URL=
CRM_SERVER_HOST=0.0.0.0
CRM_PORT=4100
CRM_ALLOWED_ORIGINS=http://127.0.0.1:3100
CRM_LOG_LEVEL=info
CRM_SUPABASE_URL=
CRM_SUPABASE_ANON_KEY=
# Conexao direta/sessao (porta 5432): usada por migrations (advisory lock) e como fallback de runtime.
CRM_DATABASE_URL=
# Opcional: pooler de transacao (Supabase Supavisor/PgBouncer, porta 6543, ?pgbouncer=true).
# Recomendado para runtime serverless (Vercel). Sem isso, o runtime usa CRM_DATABASE_URL.
CRM_DATABASE_POOL_URL=

# Auvo - placeholders, nunca usar valores reais neste arquivo
AUVO_API_KEY=
AUVO_API_TOKEN=
AUVO_WEBHOOK_SECRET=
CRON_SECRET=

# Observabilidade opcional
SENTRY_DSN=

# Credenciais de homologacao para os testes E2E (Playwright).
# Usuario real do Supabase Auth com membership gestor ativa.
# Nunca usar credenciais de producao real aqui.
EMAIL_LOGIN=
SENHA=
