generator client {
  provider = "prisma-client"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["crm", "crm_internal"]
}

model UserMembership {
  userId    String   @id @map("user_id") @db.Uuid
  role      String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid

  @@index([isActive, role], map: "user_memberships_active_role_idx")
  @@map("user_memberships")
  @@schema("crm")
}

model Customer {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoPessoa          String        @map("tipo_pessoa") @db.Text
  nome                String        @db.Text
  nomeFantasia        String?       @map("nome_fantasia") @db.Text
  telefone            String?       @db.Text
  telefoneNormalizado String?       @map("telefone_normalizado") @db.Text
  email               String?       @db.Text
  documento           String?       @db.Text
  empresa             String?       @db.Text
  bairro              String?       @db.Text
  cidade              String?       @db.Text
  estado              String?       @db.Text
  observacoes         String?       @db.Text
  auvoContactId       String?       @unique @map("auvo_contact_id") @db.Text
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdBy           String        @map("created_by") @db.Uuid
  updatedBy           String?       @map("updated_by") @db.Uuid
  archivedAt          DateTime?     @map("archived_at") @db.Timestamptz(6)
  activities          Activity[]
  nextActions         NextAction[]
  opportunities       Opportunity[]

  @@index([telefoneNormalizado], map: "clientes_telefone_normalizado_idx")
  @@map("clientes")
  @@schema("crm")
}

model PipelineStage {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String        @unique @db.Text
  ordem         Int           @unique
  isTerminal    Boolean       @default(false) @map("is_terminal")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  opportunities Opportunity[]

  @@map("etapas_funil")
  @@schema("crm")
}

model LossReason {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String        @unique @db.Text
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  opportunities Opportunity[]

  @@map("motivos_perda")
  @@schema("crm")
}

model Opportunity {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId           String        @map("cliente_id") @db.Uuid
  titulo              String        @db.Text
  descricao           String?       @db.Text
  tipoDemanda         String        @map("tipo_demanda") @db.Text
  origem              String?       @db.Text
  responsavelId       String        @map("responsavel_id") @db.Uuid
  etapaId             String        @map("etapa_id") @db.Uuid
  situacao            String        @db.Text
  valorEstimado       Int?          @map("valor_estimado")
  valorOrcamento      Int?          @map("valor_orcamento")
  valorAprovado       Int?          @map("valor_aprovado")
  formaPagamento      String?       @map("forma_pagamento") @db.Text
  quantidadeParcelas  Int?          @map("quantidade_parcelas")
  previsaoExecucao    DateTime?     @map("previsao_execucao") @db.Date
  proximaAcao         String?       @map("proxima_acao") @db.Text
  proximaAcaoEm       DateTime?     @map("proxima_acao_em") @db.Timestamptz(6)
  dataEntrada         DateTime      @default(now()) @map("data_entrada") @db.Timestamptz(6)
  dataOrcamento       DateTime?     @map("data_orcamento") @db.Timestamptz(6)
  dataAprovacao       DateTime?     @map("data_aprovacao") @db.Timestamptz(6)
  dataPerda           DateTime?     @map("data_perda") @db.Timestamptz(6)
  motivoPerdaId       String?       @map("motivo_perda_id") @db.Uuid
  status              String        @db.Text
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdBy           String        @map("created_by") @db.Uuid
  updatedBy           String?       @map("updated_by") @db.Uuid
  archivedAt          DateTime?     @map("archived_at") @db.Timestamptz(6)
  currentNextActionId String?       @map("current_next_action_id") @db.Uuid
  activities          Activity[]
  cliente             Customer      @relation(fields: [clienteId], references: [id])
  etapa               PipelineStage @relation(fields: [etapaId], references: [id])
  motivoPerda         LossReason?   @relation(fields: [motivoPerdaId], references: [id])
  nextActions         NextAction[]
  quotes              Quote[]

  @@index([clienteId], map: "oportunidades_cliente_idx")
  @@index([responsavelId, status], map: "oportunidades_responsavel_status_idx")
  @@map("oportunidades")
  @@schema("crm")
}

model Quote {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  oportunidadeId String      @map("oportunidade_id") @db.Uuid
  versao         Int
  valor          Int
  resumo         String?     @db.Text
  status         String      @db.Text
  enviadoEm      DateTime?   @map("enviado_em") @db.Timestamptz(6)
  respondidoEm   DateTime?   @map("respondido_em") @db.Timestamptz(6)
  createdBy      String      @map("created_by") @db.Uuid
  updatedBy      String?     @map("updated_by") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  oportunidade   Opportunity @relation(fields: [oportunidadeId], references: [id])

  @@unique([oportunidadeId, versao], map: "orcamentos_oportunidade_versao_unique")
  @@index([oportunidadeId, versao(sort: Desc)], map: "orcamentos_oportunidade_idx")
  @@map("orcamentos")
  @@schema("crm")
}

model Activity {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId      String       @map("cliente_id") @db.Uuid
  oportunidadeId String?      @map("oportunidade_id") @db.Uuid
  tipo           String       @db.Text
  corpo          String       @db.Text
  occurredAt     DateTime     @map("occurred_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  title          String?      @db.Text
  source         String       @default("manual") @db.Text
  metadata       Json         @default("{}")
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  archivedAt     DateTime?    @map("archived_at") @db.Timestamptz(6)
  createdBy      String       @map("created_by") @db.Uuid
  updatedBy      String?      @map("updated_by") @db.Uuid
  customer       Customer?    @relation(fields: [clienteId], references: [id])
  opportunity    Opportunity? @relation(fields: [oportunidadeId], references: [id])

  @@map("atividades")
  @@schema("crm")
}

model NextAction {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId         String       @map("customer_id") @db.Uuid
  opportunityId      String?      @map("opportunity_id") @db.Uuid
  responsibleUserId  String       @map("responsible_user_id") @db.Uuid
  category           String       @default("commercial") @db.Text
  title              String       @db.Text
  description        String?      @db.Text
  dueAt              DateTime     @map("due_at") @db.Timestamptz(6)
  priority           String       @default("normal") @db.Text
  status             String       @default("pending") @db.Text
  completedAt        DateTime?    @map("completed_at") @db.Timestamptz(6)
  completedBy        String?      @map("completed_by") @db.Uuid
  completionResult   String?      @map("completion_result") @db.Text
  postponedFrom      DateTime?    @map("postponed_from") @db.Timestamptz(6)
  createdBy          String       @map("created_by") @db.Uuid
  updatedBy          String?      @map("updated_by") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  cancelledAt        DateTime?    @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy        String?      @map("cancelled_by") @db.Uuid
  cancellationReason String?      @map("cancellation_reason") @db.Text
  archivedAt         DateTime?    @map("archived_at") @db.Timestamptz(6)
  customer           Customer     @relation(fields: [customerId], references: [id])
  opportunity        Opportunity? @relation(fields: [opportunityId], references: [id])

  @@index([responsibleUserId, status, dueAt], map: "next_actions_responsible_status_due_idx")
  @@index([category, status, dueAt], map: "next_actions_category_status_due_idx")
  @@index([customerId], map: "next_actions_customer_idx")
  @@index([opportunityId], map: "next_actions_opportunity_idx")
  @@map("next_actions")
  @@schema("crm")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName    String   @map("table_name") @db.Text
  recordId     String   @map("record_id") @db.Uuid
  action       String   @db.Text
  userId       String?  @map("user_id") @db.Uuid
  beforeValues Json?    @map("before_values")
  afterValues  Json?    @map("after_values")
  actionOrigin String   @default("app") @map("action_origin") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("audit_log")
  @@schema("crm")
}

model Notification {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  type          String    @db.Text
  priority      String    @db.Text
  severity      String    @default("attention") @db.Text
  title         String    @db.Text
  body          String?   @db.Text
  entityType    String?   @map("entity_type") @db.Text
  entityId      String?   @map("entity_id") @db.Uuid
  customerId    String?   @map("customer_id") @db.Uuid
  opportunityId String?   @map("opportunity_id") @db.Uuid
  nextActionId  String?   @map("next_action_id") @db.Uuid
  actionUrl     String?   @map("action_url") @db.Text
  dedupeKey     String?   @map("dedupe_key") @db.Text
  status        String    @default("unread") @db.Text
  readAt        DateTime? @map("read_at") @db.Timestamptz(6)
  archivedAt    DateTime? @map("archived_at") @db.Timestamptz(6)
  snoozedUntil  DateTime? @map("snoozed_until") @db.Timestamptz(6)
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz(6)
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([userId, status, createdAt], map: "notificacoes_user_status_idx")
  @@index([userId, snoozedUntil], map: "notificacoes_user_snooze_idx")
  @@index([createdAt], map: "notificacoes_created_at_idx")
  @@index([entityType, entityId], map: "notificacoes_entity_idx")
  @@map("notificacoes")
  @@schema("crm")
}

model AuvoWebhookEvent {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider             String    @default("auvo") @db.Text
  externalEventId      String?   @map("external_event_id") @db.Text
  eventType            String?   @map("event_type") @db.Text
  dedupeKey            String    @unique @map("dedupe_key") @db.Text
  status               String    @db.Text
  sanitizedHeadersJson Json      @map("sanitized_headers_json")
  rawPayloadJson       Json      @map("raw_payload_json")
  payloadHash          String    @map("payload_hash") @db.Text
  attemptCount         Int       @default(0) @map("attempt_count")
  lastError            String?   @map("last_error") @db.Text
  receivedAt           DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processingStartedAt  DateTime? @map("processing_started_at") @db.Timestamptz(6)
  processedAt          DateTime? @map("processed_at") @db.Timestamptz(6)
  ignoredAt            DateTime? @map("ignored_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  sourceIpHash         String?   @map("source_ip_hash") @db.Text
  contentLength        Int?      @map("content_length")
  schemaVersion        Int       @default(1) @map("schema_version")
  nextRetryAt          DateTime? @map("next_retry_at") @db.Timestamptz(6)

  @@index([status, receivedAt], map: "auvo_webhook_events_status_received_idx")
  @@index([payloadHash], map: "auvo_webhook_events_payload_hash_idx")
  @@index([receivedAt], map: "auvo_webhook_events_received_idx")
  @@index([externalEventId], map: "auvo_webhook_events_external_event_idx")
  @@map("auvo_webhook_events")
  @@schema("crm_internal")
}

model AuvoInboxItem {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalServiceId     String    @unique @map("external_service_id") @db.Text
  status                String    @db.Text
  suggestedCustomerId   String?   @map("suggested_customer_id") @db.Uuid
  title                 String    @db.Text
  contactName           String?   @map("contact_name") @db.Text
  phoneNormalized       String?   @map("phone_normalized") @db.Text
  auvoContactId         String?   @map("auvo_contact_id") @db.Text
  email                 String?   @db.Text
  channelType           String?   @map("channel_type") @db.Text
  resolution            String?   @db.Text
  resolvedOpportunityId String?   @map("resolved_opportunity_id") @db.Uuid
  resolvedCustomerId    String?   @map("resolved_customer_id") @db.Uuid
  resolvedBy            String?   @map("resolved_by") @db.Uuid
  resolvedAt            DateTime? @map("resolved_at") @db.Timestamptz(6)
  discardReason         String?   @map("discard_reason") @db.Text
  lastEventId           String?   @map("last_event_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt], map: "auvo_inbox_items_status_idx")
  @@index([auvoContactId], map: "auvo_inbox_items_auvo_contact_id_idx")
  @@index([phoneNormalized], map: "auvo_inbox_items_phone_normalized_idx")
  @@map("auvo_inbox_items")
  @@schema("crm_internal")
}

model MigrationHistory {
  version    String   @id @db.Text
  name       String   @db.Text
  checksum   String   @db.Text
  executedAt DateTime @default(now()) @map("executed_at") @db.Timestamptz(6)

  @@map("migration_history")
  @@schema("crm_internal")
}
